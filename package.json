{

  "name": "react-bootstrap-fontawesome",
  "version": "0.10.0",
  "description": "A TS framework for React, Bootstrap & FontAwesome.",

  "typings": "./public/dist/main.d.ts",
  "main": "./public/dist/main.js",

  "exports": {
    ".": {
      "import": {
        "types": "./public/dist/main.d.ts",
        "default": "./public/dist/main.js"
      },
      "module": {
        "types": "./public/dist/main.d.ts",
        "default": "./public/dist/main.js"
      },
      "require": {
        "types": "./public/dist/main.d.ts",
        "default": "./public/dist/main.js"
      },
      "default": "./public/dist/main.js"
    }
  },

  "scripts": {

    "lint-front": "npx eslint --config .eslintrc-front.js --ext .ts,.tsx,.cts,.mts ./public/src/**/*",
    "lint": "npm run lint-front",

    "clean-front": "npx rimraf ./public/dist",
    "clean": "npm run clean-front",

    "build-front": "npm run clean-front && npx tsc --project ./tsconfig.json",
    "build-tests": "npx webpack --config \"./webpack.config-test.js\"",
    "build": "npm run build-front && npm run build-tests",

    "check-node-engine": "npx check-node-engine",
    "check-requires": "npx used-deps-analyzer ./package.json ./public/src --no-dev",
    "check-updates": "npx check-version-modules --no-fail-at-major --fail-at-minor --fail-at-patch",
    "unit-tests": "echo 'not unit tests here'",
    "unit-tests-local": "echo 'not unit tests here'",

    "tests": "npm run lint && npm run check-node-engine && npm run check-requires && npm run check-updates && npm run build && npm run unit-tests-local"

  },

  "files": [
    "/public/dist"
  ],
  "engines": {
    "node": ">=22.22.3"
  },

  "dependencies": {},
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "check-node-engine": "1.0.0",
    "check-version-modules": "2.5.0",
    "colors": "1.4.0",
    "css-loader": "7.1.4",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "style-loader": "4.0.0",
    "ts-loader": "9.5.7",
    "used-deps-analyzer": "0.3.0",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.2"
  },

  "keywords": [
    "typescript",
    "react",
    "bootstrap",
    "typescript"
  ],

  "author": "Sébastien VIDAL",
  "license": "ISC",

  "homepage": "https://github.com/Psychopoulet/react-bootstrap-fontawesome#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/react-bootstrap-fontawesome.git"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/react-bootstrap-fontawesome/issues"
  }

}
